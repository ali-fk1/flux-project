# ================================================================
# Database
# ================================================================
DB_URL=r2dbc:postgresql://localhost:5432/your_db_name
DB_USER=your_db_username
DB_PASS=your_db_password

# ================================================================
# Keycloak
# ================================================================
# The issuer URI of your Keycloak realm — must match the 'iss' claim in JWTs
ISSUER_URI=http://localhost:8081/realms/your_realm_name

# Dedicated Postgres instance for Keycloak (runs on port 5433 via docker-compose)
KEYCLOAK_DB_NAME=your_keycloak_db_name
KEYCLOAK_DB_USER=your_keycloak_db_user
KEYCLOAK_DB_PASSWORD=pick_a_strong_password

# Keycloak admin console credentials
KEYCLOAK_ADMIN=your_keycloak_admin_user
KEYCLOAK_ADMIN_PASSWORD=pick_a_strong_password

# ================================================================
# X (Twitter) OAuth 2.0
# All values found at: https://developer.twitter.com/en/portal/dashboard
# ================================================================
# OAuth 1.0a App credentials (API key & secret from your app's "Keys and Tokens" tab)
X_API_KEY=your_x_api_key
X_API_SECRET_KEY=your_x_api_secret_key

# OAuth 2.0 PKCE redirect URI — must match exactly what's registered in the developer portal
X_V2_CALLBACK_URL=http://localhost:8080/api/x/callback

# OAuth 2.0 Client ID & Secret (from your app's "Keys and Tokens" tab, OAuth 2.0 section)
X_OAUTH2_CLIENT_ID=your_x_oauth2_client_id
X_OAUTH2_CLIENT_SECRET=your_x_oauth2_client_secret

# Length of the PKCE code verifier — 64 is recommended (min 43, max 128)
CODE_VERIFIER_LENGTH=64

# ================================================================
# Token Encryption (AES-256-GCM)
# Used to encrypt X OAuth tokens before storing them in the database
# Generate a fresh key with: openssl rand -base64 32
# ================================================================
AES_SECRET_KEY=base64_encoded_32_byte_key

# ================================================================
# App URLs
# ================================================================
# Your domain (e.g. example.com or localhost for dev)
DOMAIN=

# URL of your frontend app — used for CORS and post-OAuth redirects
FRONTEND_URL=http://localhost:5173

# Public URL of this backend — used for building callback URLs
BACKEND_URL=http://localhost:8080

# ================================================================
# AWS (S3 — upcoming)
# All values found in your AWS IAM console
# ================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=eu-west-1
AWS_S3_BUCKET_NAME=your_s3_bucket_name

# ================================================================
# LinkedIn (upcoming)
# All values found at: https://www.linkedin.com/developers/apps
# ================================================================
LINKEDIN_API_KEY=your_linkedin_api_key
LINKEDIN_API_SECRET_KEY=your_linkedin_api_secret_key
LINKEDIN_CALLBACK_URL=http://localhost:8080/api/linkedin/callback